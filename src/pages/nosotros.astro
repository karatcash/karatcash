---
import Base from '../layouts/Base.astro';
---

<Base
  title="About Us"
  description="Learn the story behind KaratCash. We believe selling your gold should be simple, fair, and transparent."
>

  <!-- HERO DARK -->
  <section class="hero-nosotros section--dark bg-image-section">
    <img src="/images/hero-bg.svg" alt="" class="hero-nosotros__pattern" aria-hidden="true" />
    <img
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIg0rAHgGbsuFsMrMYZDicDuCxWgGZ6hYS0l9MoOOc5M6F2UnIixcXnUQYd1S8XRtLg6m2TmkmantqiS6qtJOBqkoPgCcA5OxU9eq1ofA5zL8npszU-ORRzO11Y4mKCC9FkMbzWijwcmAyh7obb_juv3B08_Rz2nicpL5IZUbuO6AhrJBEhXmSdE6PSAIxNRadZwp9mquct0aLzrxxbXOQ093p79eo_H2hjm7wYModV3ZfxN8iqbYQmlrM_erju-tR_tDYAn4PyB8"
      alt=""
      class="bg-image-section__img"
      style="opacity: 0.12; filter: grayscale(1);"
      loading="eager"
    />
    <div class="bg-image-section__overlay" style="background: linear-gradient(180deg, var(--navy-deep) 20%, rgba(26,31,43,0.75) 60%, var(--navy-deep) 100%);"></div>
    <div class="hero-nosotros__glow" aria-hidden="true"></div>
    <div class="bg-image-section__content">
      <div class="container hero-nosotros__container">
        <span class="label gs-reveal">OUR STORY</span>
        <h1 class="hero-nosotros__title gs-reveal">
          We believe selling your gold<br />
          <span class="hero-nosotros__title-gold">should be simple and fair</span>
        </h1>
      </div>
    </div>
  </section>

  <!-- STORY LIGHT -->
  <section class="section section--light story">
    <div class="container">
      <div class="story__inner gs-reveal">
        <h2 class="story__heading">Why We Created KaratCash</h2>
        <p class="story__text">
          Many people across Phoenix have gold jewelry sitting in a drawer — inherited rings, gifted necklaces, pieces they no longer wear. They know those pieces have value, but they're not sure how much, and they don't trust the options available to them.
        </p>
        <p class="story__text">
          Pawn shops offer pennies on the dollar. Online buyers ask you to mail your gold with no real guarantee. And most buyers lack transparency in how they calculate their prices — leaving sellers in the dark about whether they're getting a fair deal.
        </p>
        <p class="story__text">
          KaratCash was born to change that. We're a service that comes to you, explains every step of the process, weighs your gold in front of your eyes, and pays on the spot — no fine print, no pressure, no surprises. Because selling something that was yours deserves respect.
        </p>
      </div>
    </div>
  </section>

  <!-- VALUES DARK -->
  <section class="section section--dark valores">
    <div class="container">
      <div class="valores__header gs-reveal">
        <span class="label">OUR VALUES</span>
        <h2 class="valores__title">What We Believe In</h2>
      </div>

      <div class="valores__grid">

        <article class="valor-card gs-reveal">
          <img src="/images/scale-icon.svg" alt="" class="valor-card__svg-deco" aria-hidden="true" />
          <span class="material-symbols-outlined valor-card__icon" aria-hidden="true">visibility</span>
          <h3 class="valor-card__title">Transparency</h3>
          <p class="valor-card__desc">
            We show you the live market spot price, weigh your piece in your presence, and explain every step of the calculation. Nothing stays hidden.
          </p>
        </article>

        <article class="valor-card gs-reveal">
          <span class="material-symbols-outlined valor-card__icon" aria-hidden="true">handshake</span>
          <h3 class="valor-card__title">Respect</h3>
          <p class="valor-card__desc">
            Your time and your gold have value. We show up on time, skip the unnecessary haggling, and treat you with the dignity you deserve — always.
          </p>
        </article>

        <article class="valor-card gs-reveal">
          <img src="/images/shield-check.svg" alt="" class="valor-card__svg-deco" aria-hidden="true" />
          <span class="material-symbols-outlined valor-card__icon" aria-hidden="true">shield_with_heart</span>
          <h3 class="valor-card__title">Security</h3>
          <p class="valor-card__desc">
            We meet at public locations you choose — coffee shops, shopping center parking lots, well-lit areas. Your safety always comes first.
          </p>
        </article>

      </div>
    </div>
  </section>

  <!-- CONVENIENCE CALLOUT LIGHT -->
  <section class="section section--light convenience">
    <div class="container">
      <div class="convenience__inner gs-reveal">
        <span class="label">WE COME TO YOU</span>
        <h2 class="convenience__title">No store to visit</h2>
        <p class="convenience__text">
          Forget driving across town to a storefront. KaratCash operates as a fully mobile service — we meet you wherever it's convenient in the Phoenix Valley. That means less hassle for you and a faster, more comfortable transaction. It's not a limitation; it's the advantage.
        </p>
        <a href="/contacto" class="btn btn--primary convenience__cta">
          Get Your Free Quote &rarr;
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ---- Hero ---- */
  .hero-nosotros {
    position: relative;
    padding-top: calc(var(--nav-height) + var(--space-4xl));
    padding-bottom: var(--space-4xl);
    overflow: hidden;
  }

  .hero-nosotros__glow {
    position: absolute;
    top: 40%;
    left: 50%;
    translate: -50% -50%;
    width: min(600px, 90vw);
    height: min(400px, 50vh);
    background: radial-gradient(
      ellipse at center,
      rgba(197, 165, 90, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero-nosotros__container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 760px;
  }

  .hero-nosotros__title {
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--white);
  }

  .hero-nosotros__title-gold {
    display: inline-block;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 60%, #E8CC80 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ---- Story ---- */
  .story__inner {
    max-width: 700px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .story__heading {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  .story__text {
    color: var(--gray-500);
    font-size: 1rem;
    line-height: 1.8;
  }

  /* ---- Values ---- */
  .valores__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
    text-align: center;
  }

  .valores__title {
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .valores__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    justify-items: center;
  }

  /* Hero background pattern */
  .hero-nosotros__pattern {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.03;
    pointer-events: none;
    z-index: 0;
  }

  .valor-card {
    position: relative;
    overflow: hidden;
    background-color: var(--navy);
    border: 1px solid rgba(197, 165, 90, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition:
      border-color 700ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 700ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .valor-card__svg-deco {
    position: absolute;
    bottom: -10px;
    right: -10px;
    width: 90px;
    height: 90px;
    opacity: 0.05;
    pointer-events: none;
    z-index: 0;
    transition: opacity 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .valor-card:hover .valor-card__svg-deco {
    opacity: 0.1;
  }

  .valor-card:hover {
    border-color: rgba(197, 165, 90, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .valor-card__icon {
    font-size: 2rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 32;
    flex-shrink: 0;
  }

  .valor-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .valor-card__desc {
    font-size: 0.9rem;
    color: var(--gray-400);
    line-height: 1.7;
  }

  /* ---- Convenience Callout ---- */
  .convenience__inner {
    max-width: 600px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
  }

  .convenience__title {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  .convenience__text {
    color: var(--gray-500);
    font-size: 1rem;
    line-height: 1.8;
  }

  .convenience__cta {
    margin-top: var(--space-sm);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .valores__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-nosotros {
      padding-top: calc(var(--nav-height) + var(--space-2xl));
      padding-bottom: var(--space-3xl);
    }

    .convenience__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
