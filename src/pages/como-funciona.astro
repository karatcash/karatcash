---
import Base from '../layouts/Base.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
---

<Base
  title="How It Works"
  description="Selling your gold with KaratCash is easy: contact us, we meet at a safe location, and you get paid instantly. Transparent process in Phoenix, AZ."
>

  <!-- =============================================
       1. HERO DARK
       ============================================= -->
  <section class="section section--dark cf-hero">
    <div class="cf-hero__glow" aria-hidden="true"></div>
    <div class="container cf-hero__container">
      <span class="label gs-reveal">THE PROCESS</span>
      <h1 class="cf-hero__title gs-reveal">
        Selling your gold has<br />
        <span class="cf-hero__title-gold">never been easier</span>
      </h1>
      <p class="cf-hero__subtitle gs-reveal">
        No fine print, no surprises, no waiting. Complete transparency from
        the first message to the last dollar.
      </p>
    </div>
  </section>

  <!-- =============================================
       2. STEP 1 — CONTACT US (light)
       ============================================= -->
  <section class="section section--light cf-step cf-step--deco">
    <img src="/images/gold-chain.svg" alt="" class="deco-float deco-float--gold cf-deco-step1" aria-hidden="true" />
    <div class="container cf-step__container">

      <div class="cf-step__number-col gs-reveal-left">
        <div class="cf-step__number">1</div>
      </div>

      <div class="cf-step__content gs-reveal">
        <span class="label">FIRST STEP</span>
        <h2 class="cf-step__title">Contact Us</h2>
        <p class="cf-step__desc">
          The process starts with a message. Tell us what you have — jewelry,
          coins, dental gold, broken pieces — and in minutes we'll give you
          an initial estimate with no obligation. Choose your preferred channel:
        </p>
        <div class="cf-step__badges">
          <a
            href="https://wa.me/16231234567?text=Hello%2C%20I%20want%20to%20sell%20my%20gold"
            target="_blank"
            rel="noopener noreferrer"
            class="cf-contact-badge cf-contact-badge--green"
          >
            <svg class="cf-contact-badge__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href="tel:+16231234567" class="cf-contact-badge cf-contact-badge--blue">
            <span class="material-symbols-outlined cf-contact-badge__mat-icon" aria-hidden="true">call</span>
            Call Us
          </a>
          <a href="/contacto" class="cf-contact-badge cf-contact-badge--gold">
            <span class="material-symbols-outlined cf-contact-badge__mat-icon" aria-hidden="true">edit_note</span>
            Form
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- =============================================
       3. STEP 2 — WE MEET (dark)
       ============================================= -->
  <section class="section section--dark cf-step cf-step--dark cf-step--deco">
    <img src="/images/gold-ring.svg" alt="" class="deco-float deco-float--gold cf-deco-scale" aria-hidden="true" />
    <div class="container cf-step__container cf-step__container--reverse">

      <div class="cf-step__number-col gs-reveal-right">
        <div class="cf-step__number cf-step__number--dark">2</div>
      </div>

      <div class="cf-step__content gs-reveal">
        <span class="label">SECOND STEP</span>
        <h2 class="cf-step__title cf-step__title--light">We Meet</h2>
        <p class="cf-step__desc cf-step__desc--light">
          We agree on a day, time, and place — you choose. Always at a public,
          safe location in the Phoenix Valley: a coffee shop, bank lobby,
          or shopping center. At the meeting we bring:
        </p>
        <ul class="cf-step__list">
          <li class="cf-step__list-item">
            <span class="material-symbols-outlined cf-step__list-icon" aria-hidden="true">
              scale
            </span>
            Certified precision scale
          </li>
          <li class="cf-step__list-item">
            <span class="material-symbols-outlined cf-step__list-icon" aria-hidden="true">
              science
            </span>
            Purity test kit (acid + electronic)
          </li>
          <li class="cf-step__list-item">
            <span class="material-symbols-outlined cf-step__list-icon" aria-hidden="true">
              show_chart
            </span>
            Live gold spot price
          </li>
        </ul>

        <!-- Jeweler image in double-bezel frame -->
        <div class="cf-step__image-shell">
          <div class="cf-step__image-frame">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCKy9TJQ_KtHuBuu6yJ7GGTR2uzTpEDMs5eG6xL7TEl2g6PkpMmW7Ff5Q4vqJKcMIbSqdx8WL5rUgzZmxJkIZKL7IhHWlEPc1NBuOWpIIjgL7iZET9ldD4HCzN2uiG4Zv73YTCQvY_skVZZhSJHos21SngGYMJXPR4s-0WuERvO13FypOtLlCgKj8ei_S2x96zcNnThzOeTPL-Ks3fPU8hOzTL_aEmCh8RpPbtLs8NBpAcjcXxOekkcLbUS2W1DPvYnRz76fC6-T3w"
              alt="Professional gold evaluation"
              class="cf-step__image"
              loading="lazy"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- =============================================
       4. STEP 3 — GET PAID INSTANTLY (light)
       ============================================= -->
  <section class="section section--light cf-step cf-step--deco">
    <img src="/images/gold-coins.svg" alt="" class="deco-float deco-float--gold cf-deco-step3" aria-hidden="true" />
    <div class="container cf-step__container">

      <div class="cf-step__number-col gs-reveal-left">
        <div class="cf-step__number">3</div>
      </div>

      <div class="cf-step__content gs-reveal">
        <span class="label">THIRD STEP</span>
        <h2 class="cf-step__title">Get Paid Instantly</h2>
        <p class="cf-step__desc">
          We present the offer with all the numbers on the table. If you
          accept, payment is immediate. You choose how:
        </p>

        <div class="cf-payment-cards">
          <div class="cf-payment-card">
            <span class="material-symbols-outlined cf-payment-card__icon" aria-hidden="true">payments</span>
            <h3 class="cf-payment-card__title">Cash</h3>
            <p class="cf-payment-card__desc">
              Bills in hand when we close the deal. Fast and direct.
            </p>
          </div>
          <div class="cf-payment-card">
            <span class="material-symbols-outlined cf-payment-card__icon" aria-hidden="true">account_balance</span>
            <h3 class="cf-payment-card__title">Transfer</h3>
            <p class="cf-payment-card__desc">
              Zelle, Venmo, or bank deposit — on the spot, from your phone.
            </p>
          </div>
        </div>

        <p class="cf-step__note">
          <span class="material-symbols-outlined cf-step__note-icon" aria-hidden="true">info</span>
          If the offer doesn't work for you, you take your pieces back at no cost and no pressure.
          The evaluation is always <strong>no obligation</strong>.
        </p>
      </div>

    </div>
  </section>

  <!-- =============================================
       5. WHAT DO WE BUY? — Karat cards (dark)
       ============================================= -->
  <section class="section section--dark cf-karats cf-step--deco">
    <img src="/images/gold-chain.svg" alt="" class="deco-float deco-float--gold cf-deco-shield" aria-hidden="true" />
    <div class="container">

      <div class="cf-karats__header gs-reveal">
        <span class="label">TYPES OF GOLD</span>
        <h2 class="cf-karats__title">What Do We Buy?</h2>
        <p class="cf-karats__subtitle">
          From everyday jewelry to special pieces — if it's gold, we buy it.
        </p>
      </div>

      <div class="cf-karats__grid">

        <article class="cf-karat-card gs-reveal">
          <div class="cf-karat-card__badge">10k</div>
          <h3 class="cf-karat-card__title">10 Karat Gold</h3>
          <p class="cf-karat-card__purity">41.7% pure gold</p>
          <p class="cf-karat-card__desc">
            Everyday jewelry: rings, chains, earrings. The most common in fashion jewelry.
          </p>
        </article>

        <article class="cf-karat-card gs-reveal">
          <div class="cf-karat-card__badge">14k</div>
          <h3 class="cf-karat-card__title">14 Karat Gold</h3>
          <p class="cf-karat-card__purity">58.5% pure gold</p>
          <p class="cf-karat-card__desc">
            Fine jewelry, engagement rings, bracelets. The most popular standard in the U.S.
          </p>
        </article>

        <article class="cf-karat-card gs-reveal">
          <div class="cf-karat-card__badge">18k</div>
          <h3 class="cf-karat-card__title">18 Karat Gold</h3>
          <p class="cf-karat-card__purity">75% pure gold</p>
          <p class="cf-karat-card__desc">
            Luxury jewelry, designer pieces, gemstone-encrusted items.
          </p>
        </article>

        <article class="cf-karat-card gs-reveal">
          <div class="cf-karat-card__badge">24k</div>
          <h3 class="cf-karat-card__title">24 Karat Gold</h3>
          <p class="cf-karat-card__purity">99.9% pure gold</p>
          <p class="cf-karat-card__desc">
            Coins, ingots, investment bars. The purest gold and highest value per gram.
          </p>
        </article>

      </div>

      <p class="cf-karats__note gs-reveal">
        We also buy dental gold, foreign gold coins, and any item between 10k and 24k — broken, damaged, or shapeless.
      </p>

    </div>
  </section>

  <!-- =============================================
       6. FAQ (light)
       ============================================= -->
  <section class="section section--light cf-faq">
    <div class="container">

      <div class="cf-faq__header gs-reveal">
        <span class="label">FREQUENTLY ASKED QUESTIONS</span>
        <h2 class="cf-faq__title">We've Got Answers</h2>
      </div>

      <FaqAccordion />

    </div>
  </section>

  <!-- =============================================
       7. FINAL DARK CTA
       ============================================= -->
  <section class="section section--dark cf-cta">
    <div class="cf-cta__glow" aria-hidden="true"></div>
    <div class="container cf-cta__container">

      <div class="cf-cta__text gs-reveal">
        <h2 class="cf-cta__headline">
          <span class="cf-cta__line-white">Ready to sell your gold?</span>
          <span class="cf-cta__line-gold">The process takes 20 minutes.</span>
        </h2>
        <p class="cf-cta__sub">No office. No long appointments. No waiting.</p>
      </div>

      <div class="cf-cta__actions gs-reveal">
        <a href="/contacto" class="btn btn--primary">
          <span class="material-symbols-outlined cf-cta__btn-icon" aria-hidden="true">chat_bubble</span>
          Contact Us Now
        </a>
        <a href="/calculadora" class="btn btn--outline">
          <span class="material-symbols-outlined cf-cta__btn-icon" aria-hidden="true">calculate</span>
          View the Calculator
        </a>
      </div>

    </div>
  </section>

</Base>

<style>
  /* =============================================
     HERO
     ============================================= */
  .cf-hero {
    position: relative;
    overflow: hidden;
    padding-top: calc(var(--nav-height) + var(--space-4xl));
    padding-bottom: var(--space-4xl);
  }

  .cf-hero__glow {
    position: absolute;
    top: 40%;
    left: 50%;
    translate: -50% -50%;
    width: min(600px, 90vw);
    height: min(400px, 50vh);
    background: radial-gradient(
      ellipse at center,
      rgba(197, 165, 90, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cf-hero__container {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 700px;
  }

  .cf-hero__title {
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--white);
  }

  .cf-hero__title-gold {
    display: inline-block;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 60%, #E8CC80 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cf-hero__subtitle {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    color: var(--gray-300);
    line-height: 1.75;
    max-width: 540px;
  }

  /* =============================================
     STEP SECTIONS
     ============================================= */
  .cf-step__container {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .cf-step__container--reverse {
    direction: rtl;
  }

  .cf-step__container--reverse > * {
    direction: ltr;
  }

  .cf-step__number-col {
    padding-top: var(--space-sm);
  }

  .cf-step__number {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background-color: var(--navy-deep);
    color: var(--gold);
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(197, 165, 90, 0.25);
    flex-shrink: 0;
  }

  .cf-step__number--dark {
    background-color: var(--navy);
    border-color: rgba(197, 165, 90, 0.4);
  }

  .cf-step__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .cf-step__title {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  .cf-step__title--light {
    color: var(--white);
  }

  .cf-step__desc {
    font-size: 1rem;
    color: var(--gray-500);
    line-height: 1.75;
    max-width: 580px;
  }

  .cf-step__desc--light {
    color: var(--gray-300);
  }

  /* Step list (step 2) */
  .cf-step__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cf-step__list-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--gray-200);
  }

  .cf-step__list-icon {
    color: var(--gold);
    font-size: 1.3rem;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    flex-shrink: 0;
  }

  /* Contact badges (step 1) */
  .cf-step__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .cf-contact-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .cf-contact-badge:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .cf-contact-badge--green {
    background-color: var(--green-bg);
    color: var(--green);
  }

  .cf-contact-badge--blue {
    background-color: var(--blue-bg);
    color: var(--blue);
  }

  .cf-contact-badge--gold {
    background-color: var(--gold-pale);
    color: var(--gold-dark);
  }

  .cf-contact-badge__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .cf-contact-badge__mat-icon {
    font-size: 1rem;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
  }

  /* Payment cards (step 3) */
  .cf-payment-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 520px;
  }

  .cf-payment-card {
    background-color: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .cf-payment-card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-md);
  }

  .cf-payment-card__icon {
    font-size: 1.8rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 32;
  }

  .cf-payment-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy-deep);
  }

  .cf-payment-card__desc {
    font-size: 0.85rem;
    color: var(--gray-500);
    line-height: 1.6;
  }

  /* No-obligation note */
  .cf-step__note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.88rem;
    color: var(--gray-500);
    background-color: var(--gray-100);
    border-radius: var(--radius-sm);
    padding: var(--space-md) var(--space-lg);
    max-width: 520px;
    line-height: 1.6;
  }

  .cf-step__note strong {
    color: var(--navy-deep);
  }

  .cf-step__note-icon {
    font-size: 1.1rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* =============================================
     KARATS SECTION
     ============================================= */
  .cf-karats__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .cf-karats__title {
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .cf-karats__subtitle {
    font-size: 1rem;
    color: var(--gray-400);
    max-width: 500px;
    line-height: 1.7;
  }

  .cf-karats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .cf-karat-card {
    background-color: var(--navy);
    border: 1px solid rgba(197, 165, 90, 0.18);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .cf-karat-card:hover {
    border-color: rgba(197, 165, 90, 0.45);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
  }

  .cf-karat-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--gold-dark) 0%, var(--gold) 100%);
    color: var(--navy-deep);
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-sm);
  }

  .cf-karat-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
  }

  .cf-karat-card__purity {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.03em;
  }

  .cf-karat-card__desc {
    font-size: 0.85rem;
    color: var(--gray-400);
    line-height: 1.65;
    margin-top: var(--space-xs);
  }

  .cf-karats__note {
    font-size: 0.9rem;
    color: var(--gray-400);
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    line-height: 1.7;
    padding: var(--space-lg);
    border: 1px solid rgba(197, 165, 90, 0.15);
    border-radius: var(--radius-md);
  }

  /* =============================================
     FAQ SECTION
     ============================================= */
  .cf-faq__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
    text-align: center;
  }

  .cf-faq__title {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  /* =============================================
     CTA SECTION
     ============================================= */
  .cf-cta {
    position: relative;
    overflow: hidden;
  }

  .cf-cta__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: min(600px, 90vw);
    height: 300px;
    background: radial-gradient(
      ellipse at center,
      rgba(197, 165, 90, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cf-cta__container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3xl);
  }

  .cf-cta__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

