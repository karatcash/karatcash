---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base
  title="Contacto"
  description="Contáctanos por WhatsApp, teléfono o formulario. Atendemos todo el Valle de Phoenix de lunes a sábado, 9am–7pm. Servicio 100% en español."
>

  <!-- HERO DARK -->
  <section class="hero-contacto section--dark">
    <div class="hero-contacto__glow" aria-hidden="true"></div>
    <div class="container hero-contacto__container">
      <span class="label gs-reveal">ESTAMOS PARA AYUDARTE</span>
      <h1 class="hero-contacto__title gs-reveal">Contáctanos</h1>
      <p class="hero-contacto__subtitle gs-reveal">
        Elige la forma que te quede más cómoda.
      </p>
    </div>
  </section>

  <!-- CONTENIDO LIGHT -->
  <section class="section section--light contacto-main">
    <div class="container">
      <div class="contacto-grid">

        <!-- COLUMNA IZQUIERDA — Opciones de contacto -->
        <div class="contacto-options">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/16231234567"
            target="_blank"
            rel="noopener noreferrer"
            class="option-card gs-reveal"
            aria-label="Contáctanos por WhatsApp"
          >
            <div class="option-card__icon-wrap option-card__icon-wrap--green">
              <svg class="option-card__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="option-card__body">
              <h3 class="option-card__title">WhatsApp</h3>
              <p class="option-card__desc">Escríbenos ahora, respondemos rápido</p>
            </div>
            <span class="material-symbols-outlined option-card__arrow" aria-hidden="true">arrow_forward</span>
          </a>

          <!-- Llamar -->
          <a
            href="tel:+16231234567"
            class="option-card gs-reveal"
            aria-label="Llámanos al (623) 123-4567"
          >
            <div class="option-card__icon-wrap option-card__icon-wrap--blue">
              <span class="material-symbols-outlined option-card__icon" aria-hidden="true">phone</span>
            </div>
            <div class="option-card__body">
              <h3 class="option-card__title">Llamar ahora</h3>
              <p class="option-card__desc">(623) 123-4567</p>
            </div>
            <span class="material-symbols-outlined option-card__arrow" aria-hidden="true">arrow_forward</span>
          </a>

          <!-- Horario -->
          <div class="option-card option-card--static gs-reveal">
            <div class="option-card__icon-wrap option-card__icon-wrap--gold">
              <span class="material-symbols-outlined option-card__icon" aria-hidden="true">schedule</span>
            </div>
            <div class="option-card__body">
              <h3 class="option-card__title">Horario</h3>
              <p class="option-card__desc">Lunes a Sábado: 9am – 7pm</p>
              <p class="option-card__desc">Domingo: con cita previa</p>
            </div>
          </div>

          <!-- Área de servicio -->
          <div class="option-card option-card--static gs-reveal">
            <div class="option-card__icon-wrap option-card__icon-wrap--gray">
              <span class="material-symbols-outlined option-card__icon" aria-hidden="true">location_on</span>
            </div>
            <div class="option-card__body">
              <h3 class="option-card__title">Área de servicio</h3>
              <p class="option-card__desc">Todo el Valle de Phoenix</p>
            </div>
          </div>

        </div>

        <!-- COLUMNA DERECHA — Formulario -->
        <div class="contacto-form-card gs-reveal">
          <h2 class="contacto-form-card__title">Envíanos un mensaje</h2>
          <p class="contacto-form-card__subtitle">
            Completa el formulario y te contactaremos por WhatsApp para coordinar la cita.
          </p>
          <ContactForm />
        </div>

      </div>
    </div>
  </section>

</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    gsap.utils.toArray<HTMLElement>('.gs-reveal').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
      });
    });
  });
</script>

<style>
  /* ---- Hero ---- */
  .hero-contacto {
    position: relative;
    padding-top: calc(var(--nav-height) + var(--space-4xl));
    padding-bottom: var(--space-4xl);
    overflow: hidden;
  }

  .hero-contacto__glow {
    position: absolute;
    top: 40%;
    left: 50%;
    translate: -50% -50%;
    width: min(600px, 90vw);
    height: min(400px, 50vh);
    background: radial-gradient(
      ellipse at center,
      rgba(197, 165, 90, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero-contacto__container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 640px;
  }

  .hero-contacto__title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-top: calc(-1 * var(--space-sm));
  }

  .hero-contacto__subtitle {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: var(--gray-300);
    font-weight: 400;
    line-height: 1.7;
  }

  /* ---- Main grid ---- */
  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* ---- Options column ---- */
  .contacto-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .option-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background-color: var(--white);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--navy-deep);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  a.option-card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .option-card--static {
    cursor: default;
  }

  .option-card__icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .option-card__icon-wrap--green {
    background-color: #E8F5EE;
    color: var(--green);
  }

  .option-card__icon-wrap--blue {
    background-color: var(--blue-bg);
    color: var(--blue);
  }

  .option-card__icon-wrap--gold {
    background-color: var(--gold-pale);
    color: var(--gold-dark);
  }

  .option-card__icon-wrap--gray {
    background-color: var(--gray-100);
    color: var(--gray-500);
  }

  /* WhatsApp SVG icon */
  .option-card__icon-wrap--green .option-card__icon {
    width: 22px;
    height: 22px;
  }

  /* Material icons */
  .option-card__icon {
    font-size: 1.35rem;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  }

  .option-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .option-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--navy-deep);
    line-height: 1.3;
  }

  .option-card__desc {
    font-size: 0.82rem;
    color: var(--gray-500);
    line-height: 1.5;
  }

  .option-card__arrow {
    font-size: 1.1rem;
    color: var(--gray-300);
    flex-shrink: 0;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  a.option-card:hover .option-card__arrow {
    color: var(--gold);
    transform: translateX(3px);
  }

  /* ---- Form card ---- */
  .contacto-form-card {
    background-color: var(--white);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contacto-form-card__title {
    color: var(--navy-deep);
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .contacto-form-card__subtitle {
    color: var(--gray-500);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-top: calc(-1 * var(--space-sm));
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .contacto-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 640px) {
    .hero-contacto {
      padding-top: calc(var(--nav-height) + var(--space-2xl));
      padding-bottom: var(--space-3xl);
    }

    .contacto-form-card {
      padding: var(--space-lg);
    }
  }
</style>
