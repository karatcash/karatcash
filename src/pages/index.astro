---
import Base from '../layouts/Base.astro';
import HeroHome from '../components/HeroHome.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import GoldCalculator from '../components/GoldCalculator.astro';
import PorQueKaratCash from '../components/PorQueKaratCash.astro';
import Cobertura from '../components/Cobertura.astro';
import CtaFinal from '../components/CtaFinal.astro';
---

<Base
  title="Compra de Oro en Phoenix"
  description="KaratCash compra tu oro al mejor precio en Phoenix y el área metropolitana. Proceso rápido, seguro y transparente. Cotización inmediata."
>
  <HeroHome />
  <ComoFunciona />
  <GoldCalculator compact={true} />
  <PorQueKaratCash />
  <Cobertura />
  <CtaFinal />
</Base>

<script>
  // GSAP scroll-triggered reveal animations
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    // Animate all .gs-reveal elements
    gsap.utils.toArray<HTMLElement>('.gs-reveal').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
      });
    });
  });
</script>
