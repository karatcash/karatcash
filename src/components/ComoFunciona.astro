---
// ComoFunciona — Three steps with premium card design
---

<section class="section section--light como-funciona">
  <div class="container">

    <div class="como-funciona__header gs-reveal">
      <span class="label">OUR METHOD</span>
      <h2 class="como-funciona__title">Three steps, zero hassle</h2>
    </div>

    <div class="como-funciona__grid">

      <!-- Step 1 -->
      <article class="cf-card gs-reveal">
        <div class="cf-card__bg-number" aria-hidden="true">1</div>
        <div class="cf-card__visual">
          <img src="/images/gold-chain.svg" alt="" class="cf-card__visual-img" aria-hidden="true" />
        </div>
        <div class="cf-card__top">
          <span class="cf-card__number" aria-hidden="true">1</span>
          <span class="material-symbols-outlined cf-card__icon" aria-hidden="true">chat_bubble</span>
        </div>
        <h3 class="cf-card__title">Contact Us</h3>
        <p class="cf-card__desc">
          Send us a message on WhatsApp, call us, or fill out the form. Tell us what pieces you have and we'll give you a preliminary estimate.
        </p>
        <div class="cf-card__tags">
          <span class="badge badge--green">WhatsApp</span>
          <span class="badge badge--blue">Call</span>
          <span class="badge badge--gold">Form</span>
        </div>
      </article>

      <!-- Step 2 -->
      <article class="cf-card gs-reveal">
        <div class="cf-card__bg-number" aria-hidden="true">2</div>
        <div class="cf-card__visual">
          <img src="/images/scale-icon.svg" alt="" class="cf-card__visual-img" aria-hidden="true" />
        </div>
        <div class="cf-card__top">
          <span class="cf-card__number" aria-hidden="true">2</span>
          <span class="material-symbols-outlined cf-card__icon" aria-hidden="true">location_on</span>
        </div>
        <h3 class="cf-card__title">We Meet Up</h3>
        <p class="cf-card__desc">
          We'll schedule a meeting at a safe, public location in the Phoenix Valley. We evaluate your pieces right in front of you with professional equipment.
        </p>
        <div class="cf-card__tags">
          <span class="badge badge--green">Certified Scale</span>
          <span class="badge badge--green">Purity Test</span>
        </div>
      </article>

      <!-- Step 3 -->
      <article class="cf-card gs-reveal">
        <div class="cf-card__bg-number" aria-hidden="true">3</div>
        <div class="cf-card__visual">
          <img src="/images/gold-coins.svg" alt="" class="cf-card__visual-img" aria-hidden="true" />
        </div>
        <div class="cf-card__top">
          <span class="cf-card__number" aria-hidden="true">3</span>
          <span class="material-symbols-outlined cf-card__icon" aria-hidden="true">payments</span>
        </div>
        <h3 class="cf-card__title">Get Paid Instantly</h3>
        <p class="cf-card__desc">
          If you accept the offer, you get paid right there. Cash, Zelle, or bank transfer. No fine print, no surprises.
        </p>
        <div class="cf-card__tags">
          <span class="badge badge--green">Cash</span>
          <span class="badge badge--blue">Transfer</span>
        </div>
      </article>

    </div>

  </div>
</section>

<style>
  .como-funciona {
    padding-block: var(--space-4xl);
  }

  .como-funciona__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .como-funciona__title {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  /* Grid */
  .como-funciona__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 900px) {
    .como-funciona__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  /* Card */
  .cf-card {
    position: relative;
    background-color: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    overflow: hidden;
    transition:
      background-color 700ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 700ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 700ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 700ms cubic-bezier(0.32, 0.72, 0, 1);
    cursor: default;
  }

  .cf-card:hover {
    background-color: var(--navy-deep);
    border-color: rgba(197, 165, 90, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
    transform: translateY(-4px);
  }

  /* Large faded background number */
  .cf-card__bg-number {
    position: absolute;
    top: -20px;
    right: -10px;
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 10rem;
    line-height: 1;
    color: var(--gray-100);
    pointer-events: none;
    z-index: 0;
    transition: color 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__bg-number {
    color: rgba(197, 165, 90, 0.07);
  }

  /* Visual illustration above card content */
  .cf-card__visual {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 72px;
    margin-bottom: calc(-1 * var(--space-sm));
  }

  .cf-card__visual-img {
    width: 56px;
    height: 56px;
    opacity: 0.2;
    transition: opacity 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__visual-img {
    opacity: 0.35;
  }

  /* Card top row */
  .cf-card__top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .cf-card__number {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.4rem;
    line-height: 1;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: var(--gray-100);
    color: var(--navy-deep);
    transition:
      color 700ms cubic-bezier(0.32, 0.72, 0, 1),
      background-color 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__number {
    background: rgba(197, 165, 90, 0.15);
    color: var(--gold);
  }

  .cf-card__icon {
    font-size: 2rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 32;
    transition: color 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__icon {
    color: var(--gold-light);
  }

  /* Card title */
  .cf-card__title {
    position: relative;
    z-index: 1;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy-deep);
    letter-spacing: -0.01em;
    transition: color 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__title {
    color: var(--white);
  }

  /* Card description */
  .cf-card__desc {
    position: relative;
    z-index: 1;
    font-size: 0.92rem;
    color: var(--gray-500);
    line-height: 1.7;
    flex: 1;
    transition: color 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cf-card:hover .cf-card__desc {
    color: var(--gray-300);
  }

  /* Tags */
  .cf-card__tags {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Badge color tweaks on hover */
  .cf-card:hover .badge--green {
    background-color: rgba(45, 143, 94, 0.2);
    color: #6FCF97;
  }

  .cf-card:hover .badge--blue {
    background-color: rgba(43, 108, 176, 0.2);
    color: #90CDF4;
  }

  .cf-card:hover .badge--gold {
    background-color: rgba(197, 165, 90, 0.15);
    color: var(--gold-light);
  }
</style>
