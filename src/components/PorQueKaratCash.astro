---
// PorQueKaratCash — Bento grid with visual richness and double-bezel hover
---

<section class="section section--dark pqk">
  <div class="container">

    <div class="pqk__header gs-reveal">
      <span class="label">WHY CHOOSE US</span>
      <h2 class="pqk__title">The KaratCash Difference</h2>
    </div>

    <div class="pqk__bento">

      <!-- Large card — Professional Appraisal (with jeweler bg) -->
      <article class="bento-card bento-card--large gs-reveal">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCKy9TJQ_KtHuBuu6yJ7GGTR2uzTpEDMs5eG6xL7TEl2g6PkpMmW7Ff5Q4vqJKcMIbSqdx8WL5rUgzZmxJkIZKL7IhHWlEPc1NBuOWpIIjgL7iZET9ldD4HCzN2uiG4Zv73YTCQvY_skVZZhSJHos21SngGYMJXPR4s-0WuERvO13FypOtLlCgKj8ei_S2x96zcNnThzOeTPL-Ks3fPU8hOzTL_aEmCh8RpPbtLs8NBpAcjcXxOekkcLbUS2W1DPvYnRz76fC6-T3w"
          alt=""
          class="bento-card__bg-img"
          loading="lazy"
        />
        <div class="bento-card__bg-overlay"></div>
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">verified</span>
        <div class="bento-card__content">
          <h3 class="bento-card__title">Professional Appraisal</h3>
          <p class="bento-card__desc">
            German-precision equipment to ensure you receive every cent your gold is worth.
          </p>
        </div>
        <div class="bento-card__accent" aria-hidden="true"></div>
      </article>

      <!-- Gold card — We Buy All Types of Gold -->
      <article class="bento-card bento-card--gold gs-reveal">
        <img src="/images/gold-coins.svg" alt="" class="bento-card__deco-svg" aria-hidden="true" />
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">diamond</span>
        <h3 class="bento-card__title">We Buy All Types of Gold</h3>
        <p class="bento-card__desc">
          Broken jewelry, coins, bullion, watches, and scrap from 10k to 24k.
        </p>
      </article>

      <!-- Card — Total Security -->
      <article class="bento-card gs-reveal">
        <img src="/images/shield-check.svg" alt="" class="bento-card__bg-pattern" aria-hidden="true" />
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">shield</span>
        <h3 class="bento-card__title">Total Security</h3>
        <p class="bento-card__desc">
          Meetings in monitored, safe locations.
        </p>
      </article>

      <!-- Card — Live Pricing -->
      <article class="bento-card gs-reveal">
        <img src="/images/gold-texture.svg" alt="" class="bento-card__bg-pattern" aria-hidden="true" />
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">trending_up</span>
        <h3 class="bento-card__title">Live Pricing</h3>
        <p class="bento-card__desc">
          Based on NYMEX/COMEX real-time data.
        </p>
      </article>

      <!-- Card — Fast Response -->
      <article class="bento-card bento-card--accent gs-reveal">
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">timer</span>
        <h3 class="bento-card__title">Fast Response</h3>
        <p class="bento-card__desc">
          We respond within minutes. No waiting days for a quote.
        </p>
      </article>

      <!-- Card — Instant Payment -->
      <article class="bento-card gs-reveal">
        <img src="/images/gold-bar-pattern.svg" alt="" class="bento-card__bg-pattern" aria-hidden="true" />
        <span class="material-symbols-outlined bento-card__icon" aria-hidden="true">bolt</span>
        <h3 class="bento-card__title">Instant Payment</h3>
        <p class="bento-card__desc">
          Cash, Zelle, or bank transfer on the spot.
        </p>
      </article>

    </div>

  </div>
</section>

<style>
  .pqk__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .pqk__title {
    color: var(--white);
    letter-spacing: -0.02em;
  }

  /* ---- Bento Grid ---- */
  .pqk__bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: var(--space-lg);
  }

  /* Base card — with double-bezel hover */
  .bento-card {
    position: relative;
    background-color: var(--navy);
    border: 1px solid rgba(197, 165, 90, 0.14);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    overflow: hidden;
    transition:
      border-color 700ms cubic-bezier(0.32, 0.72, 0, 1),
      transform 700ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .bento-card:hover {
    border-color: rgba(197, 165, 90, 0.4);
    transform: translateY(-3px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.3),
      inset 0 0 0 1px rgba(197, 165, 90, 0.12);
  }

  /* Background pattern images for cards */
  .bento-card__bg-pattern {
    position: absolute;
    bottom: -10px;
    right: -10px;
    width: 100px;
    height: 100px;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
    transition: opacity 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .bento-card:hover .bento-card__bg-pattern {
    opacity: 0.08;
  }

  /* Large card spans 2 rows on the left */
  .bento-card--large {
    grid-column: 1;
    grid-row: 1 / 3;
    justify-content: flex-end;
    padding: var(--space-2xl);
    min-height: 340px;
    background: linear-gradient(
      160deg,
      var(--navy-light) 0%,
      var(--navy) 60%,
      rgba(26, 31, 43, 0.9) 100%
    );
  }

  /* Background image for large card */
  .bento-card__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: grayscale(1);
    z-index: 0;
    transition: opacity 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .bento-card--large:hover .bento-card__bg-img {
    opacity: 0.45;
  }

  .bento-card__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      var(--navy-light) 0%,
      rgba(45, 52, 66, 0.85) 50%,
      rgba(26, 31, 43, 0.75) 100%
    );
    z-index: 1;
  }

  .bento-card--large .bento-card__icon,
  .bento-card--large .bento-card__content {
    position: relative;
    z-index: 2;
  }

  /* Gold accent decoration for large card */
  .bento-card__accent {
    position: absolute;
    top: -30px;
    right: -30px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(197, 165, 90, 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Gold background card */
  .bento-card--gold {
    background-color: var(--gold);
    border-color: var(--gold-dark);
    color: var(--navy-deep);
  }

  .bento-card--gold:hover {
    border-color: var(--gold-dark);
    background-color: var(--gold-light);
  }

  .bento-card--gold .bento-card__icon {
    color: var(--navy-deep);
    opacity: 0.7;
  }

  .bento-card--gold .bento-card__title {
    color: var(--navy-deep);
  }

  .bento-card--gold .bento-card__desc {
    color: rgba(26, 31, 43, 0.78);
  }

  /* Floating decoration SVG for gold card */
  .bento-card__deco-svg {
    position: absolute;
    bottom: -15px;
    right: -15px;
    width: 120px;
    height: 120px;
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
    transition: opacity 700ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .bento-card--gold:hover .bento-card__deco-svg {
    opacity: 0.2;
  }

  /* Accent card (slightly lighter) */
  .bento-card--accent {
    background-color: var(--navy-light);
  }

  /* Icon */
  .bento-card__icon {
    position: relative;
    z-index: 1;
    font-size: 2rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 32;
    flex-shrink: 0;
  }

  .bento-card--large .bento-card__icon {
    font-size: 2.8rem;
    margin-bottom: var(--space-sm);
  }

  /* Content wrapper for large card layout */
  .bento-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Title */
  .bento-card__title {
    position: relative;
    z-index: 1;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .bento-card--large .bento-card__title {
    font-size: 1.4rem;
  }

  /* Description */
  .bento-card__desc {
    position: relative;
    z-index: 1;
    font-size: 0.88rem;
    color: var(--gray-400);
    line-height: 1.7;
  }

  .bento-card--large .bento-card__desc {
    font-size: 0.95rem;
    color: var(--gray-300);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .pqk__bento {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-card--large {
      grid-column: 1 / 3;
      grid-row: auto;
      min-height: auto;
      flex-direction: row;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .bento-card--large .bento-card__icon {
      margin-bottom: 0;
    }
  }

  @media (max-width: 600px) {
    .pqk__bento {
      grid-template-columns: 1fr;
    }

    .bento-card--large {
      grid-column: 1;
      flex-direction: column;
    }
  }
</style>
