---
// Cobertura — Área de servicio (light)
import { ciudades } from '../data/ciudades';
---

<section class="section section--light cobertura">
  <div class="container">

    <div class="cobertura__header gs-reveal">
      <span class="label">SERVICE AREA</span>
      <h2 class="cobertura__title">Serving the entire Phoenix Valley</h2>
      <p class="cobertura__subtitle">
        We travel anywhere in the Phoenix metro area to meet you in a safe, convenient location.
      </p>
    </div>

    <div class="cobertura__pills gs-reveal" role="list" aria-label="Cities we serve">
      {ciudades.map((ciudad) => (
        <span class="cobertura__pill" role="listitem">{ciudad}</span>
      ))}
      <span class="cobertura__pill cobertura__pill--more" role="listitem">and more&hellip;</span>
    </div>

    <p class="cobertura__note gs-reveal">
      <span class="material-symbols-outlined cobertura__note-icon" aria-hidden="true">location_on</span>
      Don't see your city? Contact us — we can probably get there.
    </p>

  </div>
</section>

<style>
  .cobertura__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
    max-width: 600px;
  }

  .cobertura__title {
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  .cobertura__subtitle {
    font-size: 1rem;
    color: var(--gray-500);
    line-height: 1.7;
  }

  /* Pills container */
  .cobertura__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  /* Individual pill */
  .cobertura__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    background-color: var(--gray-100);
    border: 1px solid var(--gray-200);
    color: var(--navy);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .cobertura__pill:hover {
    background-color: var(--gold-pale);
    border-color: var(--gold);
    color: var(--gold-dark);
  }

  .cobertura__pill--more {
    color: var(--gray-400);
    border-style: dashed;
    background-color: transparent;
    font-weight: 500;
    font-style: italic;
  }

  .cobertura__pill--more:hover {
    background-color: transparent;
    color: var(--gray-500);
    border-color: var(--gray-300);
  }

  /* Bottom note */
  .cobertura__note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.88rem;
    color: var(--gray-400);
    font-weight: 500;
  }

  .cobertura__note-icon {
    font-size: 1.1rem;
    color: var(--gold);
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
  }
</style>
